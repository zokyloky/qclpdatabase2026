# Copy this file to .env and fill in the values before running locally.
# On Render, set these as environment variables in the dashboard.

# Shared access password for the web app (no user accounts — just one password)
APP_PASSWORD=choose_a_strong_password_here

# Random secret key for signing JWT tokens — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_string

# Supabase Postgres connection string
# Find in: Supabase dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.wbyuqjvdlavvxpzspygc.supabase.co:5432/postgres

# Supabase project URL and anon key (used for any client-side Supabase calls)
SUPABASE_URL=https://wbyuqjvdlavvxpzspygc.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndieXVxanZkbGF2dnhwenNweWdjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ1ODkwOTYsImV4cCI6MjA5MDE2NTA5Nn0.ScIJYzBT2NoC0mweuhvsZFv2Jhhq2adkJBdUTh_moUE

